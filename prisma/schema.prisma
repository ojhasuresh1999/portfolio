// Portfolio Database Schema
// Prisma ORM with PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  image         String?
  role          Role      @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// ============================================
// HERO SECTION
// ============================================

model HeroContent {
  id              String   @id @default(cuid())
  title           String   // "Architecting the Invisible Backbone."
  highlightWord   String   // "Invisible"
  terminalCommand String   // "init backend_protocol --force"
  description     String
  ctaPrimaryText  String   @default("Initialize Project")
  ctaPrimaryLink  String   @default("#contact")
  ctaSecondaryText String  @default("View Source")
  ctaSecondaryLink String  @default("#")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// TECHNICAL ARSENAL (Tech Stack)
// ============================================

model TechStack {
  id          String   @id @default(cuid())
  name        String   // "Node.js"
  icon        String   // Material icon name or custom icon
  color       String   // Icon color
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// PROJECTS (Deployments)
// ============================================

model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  longDescription String?
  image        String?
  codeSnippet  String?  // Code shown in project card
  technologies String[] // Array of tech tags
  liveUrl      String?
  githubUrl    String?
  accentColor  String   @default("primary") // "primary" or "secondary"
  order        Int      @default(0)
  isFeatured   Boolean  @default(false)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// SKILLS
// ============================================

model Skill {
  id          String     @id @default(cuid())
  name        String
  proficiency Int        // 0-100
  category    SkillCategory
  order       Int        @default(0)
  isVisible   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum SkillCategory {
  LANGUAGE
  DATABASE
  DEVOPS
  FRAMEWORK
  TOOL
}

model SkillCard {
  id          String   @id @default(cuid())
  title       String   // "Core Runtime"
  description String
  icon        String   // Material icon name
  tags        String[] // ["Node.js v20+", "Deno", "Bun"]
  gridSpan    String   @default("1") // "1", "2", or "full"
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// BLOG POSTS
// ============================================

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   // Rich text / Markdown
  coverImage  String?
  category    String   // "Performance", "Database", "Security"
  tags        String[]
  readTime    Int      @default(5) // minutes
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// ABOUT / TIMELINE
// ============================================

model TimelineEntry {
  id          String   @id @default(cuid())
  year        String   // "2024 - Present"
  title       String   // "Lead Backend Architect"
  description String
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AboutContent {
  id          String   @id @default(cuid())
  title       String   @default("More Than Just Code")
  subtitle    String   @default("About Me")
  description String
  resumeUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// SOCIAL LINKS
// ============================================

model SocialLink {
  id        String   @id @default(cuid())
  platform  String   // "GitHub", "LinkedIn", "Email"
  url       String
  icon      String   // Icon identifier
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// SITE SETTINGS
// ============================================

model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("DEV_IO")
  siteTagline     String   @default("Backend Developer Portfolio")
  logoText        String   @default("DEV_IO")
  statusText      String   @default("System Online")
  footerLatency   String   @default("12ms")
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// CONTACT SUBMISSIONS
// ============================================

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
